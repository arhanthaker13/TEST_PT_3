# Flask
FLASK_DEBUG=false

# Database (defaults to SQLite if not set)
DATABASE_URL=postgresql://user:password@localhost:5432/papertrail

# Semantic Scholar (optional — unauthenticated works but is heavily rate-limited)
SEMANTIC_SCHOLAR_API_KEY=your_api_key_here

# OpenAlex (optional — include your email for polite-pool access with higher rate limits)
OPENALEX_EMAIL=your_email@example.com
